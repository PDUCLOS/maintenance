# =============================================================================
# Industrial Knowledge Copilot — Environment variables
# Copy to .env and adjust values. .env is gitignored.
# =============================================================================

# --- Hardware target --------------------------------------------------------
# MLX runs natively on Apple Silicon (M1/M2/M3/M4/M5). On other platforms,
# the LLM/embedding components will fail at startup (intentional — no mock).
HARDWARE_TARGET=apple_silicon
# Estimated on MacBook Pro M5 Pro: ~5 GB RAM for Mistral 7B 4-bit + ~0.3 GB
# for embeddings. Latency: 2-5 sec/query with Metal acceleration.

# --- LLM (MLX) --------------------------------------------------------------
# Mistral 7B Instruct in MLX 4-bit (quantized) from mlx-community on HF Hub.
# Will be downloaded on first run by src/rag/llm.py (~4.5 GB on disk).
MLX_MODEL_REPO=mlx-community/Mistral-7B-Instruct-v0.3-4bit
MLX_MODEL_PATH=${HOME}/.cache/huggingface/hub

# Generation parameters
MLX_MAX_TOKENS=1024
MLX_TEMPERATURE=0.1
MLX_TOP_P=0.9

# --- Embeddings (MLX) -------------------------------------------------------
# bge-small (EN, 33M params) for speed. Switch to nomic-embed (137M, multi)
# if you add multilingual PDF docs in W3-W4.
MLX_EMBED_REPO=mlx-community/bge-small-en-v1.5-4bit
EMBED_DIM=384

# --- ChromaDB (Docker) ------------------------------------------------------
# Chroma server runs in docker-compose. Host port 8001 -> container 8000.
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=cmapss_kb

# --- API (FastAPI) ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# --- UI (Streamlit) ---------------------------------------------------------
UI_PORT=8501

# --- Paths ------------------------------------------------------------------
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
CHUNKS_FILE=./data/processed/chunks.jsonl
EVAL_DATASET_FILE=./data/processed/eval_dataset.jsonl
CMAPSS_DIR=./data/raw/cmapss
PDF_DIR=./data/raw/pdf

# --- RAG --------------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVER_TOP_K=5
HYBRID_SEARCH=true
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
