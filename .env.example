# =============================================================================
# Industrial Knowledge Copilot — Environment variables
# Copy to .env and adjust values. .env is gitignored.
# =============================================================================

# --- Hardware target --------------------------------------------------------
# MLX runs natively on Apple Silicon (M1/M2/M3/M4/M5). On other platforms,
# the LLM/embedding components will fail at startup (intentional — no mock).
HARDWARE_TARGET=apple_silicon
# Estimated on MacBook Pro M5 Pro: ~5 GB RAM for Qwen2.5-7B 4-bit + ~0.3 GB
# for embeddings. Latency: 2-5 sec/query with Metal acceleration.

# --- LLM (MLX) --------------------------------------------------------------
# Qwen2.5-7B-Instruct in MLX 4-bit (quantized) from mlx-community on HF Hub.
# Will be downloaded on first run by src/rag/llm.py (~4.5 GB on disk).
# Chosen over Mistral-7B-Instruct-v0.3 after an A/B test on the ReAct agent
# harness (5 quantitative questions, same 4-bit/7B footprint): Mistral scored
# 2/5 clean tool invocations; Qwen2.5 scored 5/5. See PLAN.md §8.
MLX_MODEL_REPO=mlx-community/Qwen2.5-7B-Instruct-4bit
MLX_MODEL_PATH=${HOME}/.cache/huggingface/hub

# Generation parameters
MLX_MAX_TOKENS=1024
MLX_TEMPERATURE=0.1
MLX_TOP_P=0.9

# --- Embeddings --------------------------------------------------------------
# bge-small (EN, 33M params) for speed. Switch to nomic-embed (137M, multi)
# if you add multilingual PDF docs in W3-W4.
# NOTE: must be a standard (unquantized) sentence-transformers checkpoint —
# loaded via sentence-transformers/device="mps", not MLX. The mlx-community
# "-4bit" variants ship MLX-packed weights that don't load here.
MLX_EMBED_REPO=BAAI/bge-m3
EMBED_DIM=1024

# --- ChromaDB (Docker) ------------------------------------------------------
# Chroma server runs in docker-compose. Host port 8001 -> container 8000.
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=bearings_kb

# --- API (FastAPI) ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
# Hard timeout on /query. If the LLM takes longer, the API returns 504.
# 60s leaves headroom for: retrieval (~100 ms) + LLM gen (~2-5s typical,
# can spike to ~30s on cold start or long prompts).
QUERY_TIMEOUT_SECONDS=60

# --- UI (Streamlit) ---------------------------------------------------------
UI_PORT=8501

# --- Paths ------------------------------------------------------------------
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
CHUNKS_FILE=./data/processed/chunks.jsonl
EVAL_DATASET_FILE=./data/processed/eval_dataset.jsonl
PDF_DIR=./data/raw/pdf

# --- RAG --------------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVER_TOP_K=5
HYBRID_SEARCH=true
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
