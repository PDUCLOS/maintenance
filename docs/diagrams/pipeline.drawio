          </mxGeometry>
        </mxCell>
        <mxCell id="s2" edge="1" parent="1" source="ll-ui" style="endArrow=classic;html=1;strokeColor=#000000" target="ll-api" value="2. POST /query {question, top_k}">
          <mxGeometry relative="1" as="geometry">
            <mxPoint y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3" edge="1" parent="1" source="ll-api" style="endArrow=classic;html=1;strokeColor=#000000" target="ll-chain" value="3. chain.query(question)">
