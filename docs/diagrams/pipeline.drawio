          <mxGeometry relative="1" as="geometry">
            <mxPoint x="430" y="120" as="sourcePoint" />
            <mxPoint x="430" y="1100" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l4" style="endArrow=none;dashed=1;html=1;strokeColor=#999999" edge="1" parent="1" source="ll-chain" target="ll-chain">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="590" y="120" as="sourcePoint" />
            <mxPoint x="590" y="1100" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l5" style="endArrow=none;dashed=1;html=1;strokeColor=#999999" edge="1" parent="1" source="ll-emb" target="ll-emb">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="750" y="120" as="sourcePoint" />
            <mxPoint x="750" y="1100" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l6" style="endArrow=none;dashed=1;html=1;strokeColor=#999999" edge="1" parent="1" source="ll-ret" target="ll-ret">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="910" y="120" as="sourcePoint" />
            <mxPoint x="910" y="1100" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l7" style="endArrow=none;dashed=1;html=1;strokeColor=#999999" edge="1" parent="1" source="ll-llm" target="ll-llm">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1070" y="120" as="sourcePoint" />
            <mxPoint x="1070" y="1100" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Steps -->
        <mxCell id="s1" value="1. Type question + send" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-user" target="ll-ui">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s2" value="2. POST /query {question, top_k}" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-ui" target="ll-api">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3" value="3. chain.query(question)" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-api" target="ll-chain">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s4" value="4. embed([question]) → qv (384-dim, ~50ms on M-series)" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-chain" target="ll-emb">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5" value="5. retrieve(q, k=5) — RRF(dense, BM25)" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-chain" target="ll-ret">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s6" value="5a. dense: chroma query (HTTP, ~30ms)" style="endArrow=classic;html=1;strokeColor=#6c8ebf;dashed=1" edge="1" parent="1" source="ll-ret">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s6b" value="5b. BM25: in-mem scan (~5ms for &lt; 5k chunks)" style="endArrow=classic;html=1;strokeColor=#6c8ebf;dashed=1" edge="1" parent="1" source="ll-ret">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s7" value="6. context (top-5 chunks, formatted) + question" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-chain" target="ll-llm">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s8" value="7. mlx_lm.generate(...) → answer (2-5s on M-series GPU)" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-llm" target="ll-chain">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s9" value="8. RAGResponse{answer, sources}" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-chain" target="ll-api">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s10" value="9. JSON {answer, sources, latency_ms}" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-api" target="ll-ui">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s11" value="10. Render markdown + sources in chat" style="endArrow=classic;html=1;strokeColor=#000000" edge="1" parent="1" source="ll-ui" target="ll-user">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="-5" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Latency annotation -->
        <mxCell id="latency-note" value="Typical latency budget on MacBook Pro M5 Pro:&#10;embed 50ms + retrieve 35ms + LLM generate 2-5s + overhead 50ms = ~3-6s end-to-end" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left" vertex="1" parent="1">
          <mxGeometry x="40" y="900" width="540" height="80" as="geometry" />
        </mxCell>

        <!-- Cross-cutting concerns -->
        <mxCell id="xcut" value="Cross-cutting (every step):&#10;• loguru: emit JSON event with question_id, latency, chunk_count, model&#10;• Pydantic validation on request/response&#10;• Hardware guard: MLX refuses to load on non-Apple-Silicon (fail-fast)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left" vertex="1" parent="1">
          <mxGeometry x="620" y="900" width="500" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
