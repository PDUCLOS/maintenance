        <mxCell id="latency-note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left" value="Typical latency budget on MacBook Pro M5 Pro:&#xa;embed 50ms + retrieve 35ms + LLM generate 2-5s + overhead 50ms = ~3-6s end-to-end" vertex="1">
          <mxGeometry height="80" width="540" x="40" y="900" as="geometry" />
        </mxCell>
        <mxCell id="xcut" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left" value="Cross-cutting (every step):&#xa;• loguru: emit JSON event with question_id, latency, chunk_count, model&#xa;• Pydantic validation on request/response&#xa;• Hardware guard: MLX refuses to load on non-Apple-Silicon (fail-fast)" vertex="1">
          <mxGeometry height="100" width="500" x="620" y="900" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
